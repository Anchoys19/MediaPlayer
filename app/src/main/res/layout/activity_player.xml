<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Плеєр"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- ExoPlayer VideoView (для відео) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:layout_marginBottom="12dp"/>

    <!-- Іконка ноти для аудіо (завжди видима, перекривається PlayerView для відео) -->
    <TextView
        android:id="@+id/tvAudioIcon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="🎵"
        android:textSize="80sp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progressTint="#1DB954"
        android:thumbTint="#1DB954"
        android:layout_marginBottom="8dp"/>

    <!-- Час -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#BBBBBB"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#BBBBBB"
            android:textSize="13sp"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Кнопки керування -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_stop"
            android:background="@drawable/circle_button_bg"
            android:layout_marginEnd="32dp"
            android:contentDescription="Стоп"/>

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_pause"
            android:background="@drawable/circle_button_green_bg"
            android:contentDescription="Відтворити/Пауза"/>

    </LinearLayout>

</LinearLayout>